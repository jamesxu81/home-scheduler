{
  "name": "kimberly-scheduler",
  "version": "1.0.0",
  "description": "Kimberly's Scheduler - A family schedule management application for managing events and activities",
  "private": true,
  "scripts": {
    "setup-schema": "node scripts/setup-schema.js",
    "dev": "npm run setup-schema && next dev",
    "prebuild": "npm run setup-schema && npm test -- --passWithNoTests",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "npm test -- --passWithNoTests",
    "test:e2e": "playwright test",
    "test:e2e:watch": "playwright test --watch",
    "test:all": "npm run test -- --passWithNoTests && npm run test:e2e"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "next": "^16.1.6",
    "prisma": "^5.22.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.40.1",
    "@testing-library/jest-dom": "^6.1.5",
    "@testing-library/react": "^15.0.0",
    "@types/jest": "^29.5.11",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.4.14",
    "eslint": "^8.57.0",
    "eslint-config-next": "^16.1.6",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.4.1",
    "ts-jest": "^29.1.1",
    "typescript": "^5.3.3"
  },
  "keywords": [
    "family",
    "scheduler",
    "events",
    "kids"
  ],
  "author": "Family Team",
  "license": "MIT"
}
